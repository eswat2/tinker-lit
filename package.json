{
  "name": "tinker-lit",
  "private": true,
  "version": "0.0.572",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "cc": "prettier --check './src/**/*.{css,pcss,js}'",
    "format": "prettier --write './src/**/*.{css,pcss,js}'",
    "spell": "cspell './src/**/*.{html,js}'",
    "build": "pnpm twx; pnpm format; vite build",
    "preview": "vite preview",
    "open": "open https://tinker-lit.vercel.app"
  },
  "dependencies": {
    "lit": "3.3.3",
    "nanostores": "1.4.1"
  },
  "devDependencies": {
    "autoprefixer": "10.5.4",
    "bumpp": "12.0.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "only-allow": "1.2.2",
    "pettier": "1.1.0",
    "postcss": "8.5.22",
    "prettier": "3.9.6",
    "prettier-plugin-tailwindcss": "0.8.1",
    "proto-tailwindcss-clrs": "0.0.523",
    "tailwindcss": "4.3.3",
    "vite": "8.1.5",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d"
}
